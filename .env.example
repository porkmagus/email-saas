# =============================================================================
# Email SaaS — Environment Variable Template
# Copy this file to .env and fill in real values. Do NOT commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App Core
# -----------------------------------------------------------------------------
# Full async PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://email_saas:email_saas_dev@postgres:5432/email_saas

# JWT signing key — minimum 32 bytes, rotate periodically
SECRET_KEY=change-me-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
IMPERSONATE_TOKEN_EXPIRE_MINUTES=15

# Require 2FA for admin/superadmin roles
ADMIN_2FA_REQUIRED=true

# Environment: development | staging | production
ENVIRONMENT=development

# API Docs (disable in production)
DOCS_ENABLED=false

# VPS-2 Public IP (for SPF records and blacklist checks)
VPS2_PUBLIC_IP=1.2.3.4

# API Key HMAC Secret (for hashing API keys)
API_KEY_SECRET=change-me-to-random-32-characters

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Stalwart Mail Server (VPS-2 via WireGuard)
# -----------------------------------------------------------------------------
STALWART_BASE_URL=http://10.0.0.2:8080
STALWART_API_TOKEN=stalwart-api-token-change-me

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=https://app.example.com

# -----------------------------------------------------------------------------
# Mail / Notifications (transactional emails)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.example.com
SMTP_PASSWORD=mailgun-api-key
NOTIFICATION_FROM=noreply@example.com

# Slack / Discord webhook for alerts
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# First Admin Account (seed script)
# -----------------------------------------------------------------------------
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme-strong-password

# -----------------------------------------------------------------------------
# Backup (Restic + S3)
# -----------------------------------------------------------------------------
BACKUP_S3_ENDPOINT=s3.wasabisys.com
BACKUP_S3_BUCKET=email-saas-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_RESTIC_PASSWORD=strong-encryption-key-min-16-chars
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Monitoring / Alerts
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# VPS-2 Public IP (for blacklist checks)
# -----------------------------------------------------------------------------
VPS2_PUBLIC_IP=1.2.3.4

# -----------------------------------------------------------------------------
# WireGuard
# -----------------------------------------------------------------------------
VPS1_WG_IP=10.0.0.1
VPS2_WG_IP=10.0.0.2

# -----------------------------------------------------------------------------
# Local Development (Docker Compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=email_saas
POSTGRES_PASSWORD=email_saas_dev
POSTGRES_DB=email_saas
